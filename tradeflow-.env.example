# TRADEFLOW AI — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs

# ─── OBLIGATOIRE ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx

# ─── TON ENTREPRISE ──────────────────────────
ARTISAN_NAME=Martin Électricité
ARTISAN_SIRET=123 456 789 00010
ARTISAN_TVA_INTRA=FR12345678900
ARTISAN_ADDRESS=12 Rue de la Paix, 75001 Paris
ARTISAN_EMAIL=jean@martin-electricite.fr
ARTISAN_PHONE=+33612345678

# ─── TWILIO (SMS) ────────────────────────────
# twilio.com → Console → Account SID + Auth Token
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=+33XXXXXXXXX
# Ton numéro perso pour recevoir les SMS
ARTISAN_PHONE=+33612345678

# ─── RESEND (EMAIL) ──────────────────────────
# resend.com → API Keys → Create
RESEND_API_KEY=re_xxx

# ─── MAKE.COM (GOOGLE SHEETS) ────────────────
# make.com → Webhooks → Custom Webhook → Copy URL
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/xxx
